# Neon PostgreSQL — copie a connection string do painel Neon
# Exemplo: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Chave secreta para rotas protegidas — use uma string longa e aleatória
ADMIN_SECRET=troque-por-uma-senha-segura-aqui

# Porta do servidor Express
PORT=3000

# Origem permitida pelo CORS — URL da sua landing page
# Para desenvolvimento local use: http://localhost:5500
CORS_ORIGIN=https://fitai.com.br
